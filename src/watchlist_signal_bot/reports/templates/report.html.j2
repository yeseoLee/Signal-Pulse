<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Watchlist Signal Bot</title>
    <style>
      :root {
        --bg: #f6f1e8;
        --panel: rgba(255, 252, 247, 0.9);
        --ink: #15202b;
        --muted: #667481;
        --line: rgba(21, 32, 43, 0.1);
        --rise: #0f766e;
        --flat: #9a6b21;
        --fall: #9f1239;
        --accent: #c46a2f;
        --shadow: 0 20px 44px rgba(21, 32, 43, 0.08);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        color: var(--ink);
        font-family: "IBM Plex Sans", "Noto Sans KR", sans-serif;
        background:
          radial-gradient(circle at top left, rgba(196, 106, 47, 0.14), transparent 28%),
          radial-gradient(circle at top right, rgba(15, 118, 110, 0.12), transparent 24%),
          linear-gradient(180deg, #fff8ee 0%, var(--bg) 100%);
      }

      .page {
        max-width: 1280px;
        margin: 0 auto;
        padding: 32px 20px 72px;
      }

      .hero,
      .panel,
      .card {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 24px;
        box-shadow: var(--shadow);
      }

      .hero {
        padding: 28px;
      }

      .hero-grid {
        display: grid;
        grid-template-columns: 1.6fr 1fr;
        gap: 18px;
        align-items: start;
      }

      h1,
      h2,
      h3,
      p {
        margin: 0;
      }

      h1,
      h2 {
        font-family: "IBM Plex Serif", "Noto Serif KR", serif;
      }

      h1 {
        font-size: clamp(2.2rem, 5vw, 3.4rem);
        line-height: 0.95;
        letter-spacing: -0.04em;
      }

      h2 {
        font-size: 1.5rem;
        margin-bottom: 16px;
      }

      .muted {
        color: var(--muted);
      }

      .hero-copy {
        display: grid;
        gap: 14px;
      }

      .hero-copy p {
        max-width: 44rem;
        line-height: 1.55;
      }

      .stat-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
      }

      .stat {
        padding: 16px;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.68);
        border: 1px solid rgba(21, 32, 43, 0.08);
      }

      .stat strong {
        display: block;
        margin-bottom: 4px;
        font-size: 1.7rem;
      }

      .section {
        margin-top: 24px;
      }

      .panel {
        padding: 22px;
      }

      .table-wrap {
        overflow-x: auto;
      }

      table {
        width: 100%;
        border-collapse: collapse;
      }

      th,
      td {
        padding: 12px 0;
        border-bottom: 1px solid rgba(21, 32, 43, 0.08);
        text-align: left;
        vertical-align: top;
      }

      th {
        color: var(--muted);
        font-weight: 600;
      }

      .section-title {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 14px;
      }

      .card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 18px;
      }

      .card {
        padding: 22px;
        position: relative;
        overflow: hidden;
      }

      .card::after {
        content: "";
        position: absolute;
        right: -28px;
        bottom: -28px;
        width: 120px;
        height: 120px;
        border-radius: 999px;
        background: linear-gradient(135deg, rgba(196, 106, 47, 0.16), transparent);
      }

      .card-top {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: flex-start;
        margin-bottom: 12px;
      }

      .card-top strong {
        display: block;
        font-size: 1.18rem;
        margin-bottom: 4px;
      }

      .price {
        text-align: right;
        font-size: 1.05rem;
        font-weight: 700;
      }

      .chip-row,
      .metric-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .chip,
      .metric {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        white-space: nowrap;
        word-break: keep-all;
      }

      .chip {
        padding: 6px 10px;
        font-size: 0.82rem;
        border: 1px solid transparent;
      }

      .chip-trend-up {
        background: rgba(15, 118, 110, 0.1);
        color: var(--rise);
        border-color: rgba(15, 118, 110, 0.18);
      }

      .chip-trend-flat {
        background: rgba(154, 107, 33, 0.1);
        color: var(--flat);
        border-color: rgba(154, 107, 33, 0.18);
      }

      .chip-trend-down {
        background: rgba(159, 18, 57, 0.1);
        color: var(--fall);
        border-color: rgba(159, 18, 57, 0.18);
      }

      .chip-level {
        background: rgba(255, 255, 255, 0.72);
        border-color: rgba(21, 32, 43, 0.08);
      }

      .metric {
        padding: 10px 12px;
        min-width: 88px;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.72);
        border: 1px solid rgba(21, 32, 43, 0.08);
        flex-direction: column;
        align-items: flex-start;
      }

      .metric span {
        font-size: 0.74rem;
        color: var(--muted);
        margin-bottom: 4px;
      }

      .summary-block {
        margin-top: 14px;
        display: grid;
        gap: 10px;
      }

      .summary-block p {
        line-height: 1.55;
      }

      .label {
        color: var(--muted);
        font-size: 0.82rem;
        margin-bottom: 6px;
      }

      .sparkline {
        width: 100%;
        height: 68px;
        margin-top: 14px;
      }

      .sparkline polyline {
        fill: none;
        stroke: var(--accent);
        stroke-width: 3;
        stroke-linecap: round;
        stroke-linejoin: round;
      }

      .empty {
        color: var(--muted);
      }

      .footer {
        margin-top: 22px;
        color: var(--muted);
        font-size: 0.92rem;
      }

      @media (max-width: 900px) {
        .hero-grid,
        .stat-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <div class="page">
      <section class="hero">
        <div class="hero-grid">
          <div class="hero-copy">
            <p class="muted">주간 기술적 분석 보고서</p>
            <h1>Watchlist Signal Bot</h1>
            <p>
              이동평균선 기반 추세, pivot 기반 지지·저항, 20일·60일·120일 수익률을
              기준으로 관심 종목의 현재 구조를 요약합니다.
            </p>
            <p class="muted">기준일 {{ as_of }}</p>
          </div>
          <div class="stat-grid">
            <div class="stat">
              <strong>{{ total_symbols }}</strong>
              <span class="muted">점검 종목</span>
            </div>
            <div class="stat">
              <strong>{{ uptrend_count }}</strong>
              <span class="muted">상승 추세</span>
            </div>
            <div class="stat">
              <strong>{{ sideways_count }}</strong>
              <span class="muted">횡보</span>
            </div>
            <div class="stat">
              <strong>{{ downtrend_count }}</strong>
              <span class="muted">하락 추세</span>
            </div>
          </div>
        </div>
      </section>

      <section class="section panel">
        <div class="section-title">
          <h2>추세 변화</h2>
          <span class="muted">직전 기록 대비 라벨 변경</span>
        </div>
        {% if trend_change_rows %}
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>종목</th>
                  <th>이전</th>
                  <th>현재</th>
                  <th>20일 수익률</th>
                  <th>60일 수익률</th>
                  <th>120일 수익률</th>
                </tr>
              </thead>
              <tbody>
                {% for row in trend_change_rows %}
                  <tr>
                    <td>{{ row.symbol }} ({{ row.name }})</td>
                    <td>{{ row.previous_trend_label }}</td>
                    <td>{{ row.trend_label }}</td>
                    <td>{{ "%.1f"|format(row.return_20d) if row.return_20d == row.return_20d else "-" }}%</td>
                    <td>{{ "%.1f"|format(row.return_60d) if row.return_60d == row.return_60d else "-" }}%</td>
                    <td>{{ "%.1f"|format(row.return_120d) if row.return_120d == row.return_120d else "-" }}%</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        {% else %}
          <p class="empty">오늘은 직전 기록 대비 추세 라벨이 바뀐 종목이 없습니다.</p>
        {% endif %}
      </section>

      {% for section in trend_sections %}
        <section class="section panel">
          <div class="section-title">
            <h2>{{ section.label }}</h2>
            <span class="muted">{{ section.count }}개 종목</span>
          </div>
          {% if section.cards %}
            <div class="card-grid">
              {% for card in section.cards %}
                <article class="card">
                  <div class="card-top">
                    <div>
                      <strong>{{ card.symbol }} ({{ card.name }})</strong>
                      <p class="muted">{{ card.market }} · {{ card.group }}</p>
                    </div>
                    <div class="price">{{ card.price }}</div>
                  </div>

                  <div class="chip-row">
                    <span class="chip {{ card.trend_badge_class }}">기준 {{ card.trend_label }}</span>
                    {% for item in card.trend_breakdown %}
                      <span class="chip {{ item.class_name }}">{{ item.label }}</span>
                    {% endfor %}
                  </div>

                  <svg class="sparkline" viewBox="0 0 220 64" preserveAspectRatio="none" aria-hidden="true">
                    <polyline points="{{ card.sparkline_points }}"></polyline>
                  </svg>

                  <div class="metric-row">
                    {% for metric in card.returns %}
                      <div class="metric">
                        <span>{{ metric.label }}</span>
                        <strong>{{ metric.value }}</strong>
                      </div>
                    {% endfor %}
                  </div>

                  <div class="summary-block">
                    <div>
                      <p class="label">추세 해석</p>
                      <p>{{ card.trend_summary }}</p>
                    </div>

                    <div>
                      <p class="label">주요 지지</p>
                      <div class="chip-row">
                        {% if card.supports %}
                          {% for item in card.supports %}
                            <span class="chip chip-level">{{ item }}</span>
                          {% endfor %}
                        {% else %}
                          <span class="empty">가까운 지지 구간이 뚜렷하지 않습니다.</span>
                        {% endif %}
                      </div>
                    </div>

                    <div>
                      <p class="label">주요 저항</p>
                      <div class="chip-row">
                        {% if card.resistances %}
                          {% for item in card.resistances %}
                            <span class="chip chip-level">{{ item }}</span>
                          {% endfor %}
                        {% else %}
                          <span class="empty">가까운 저항 구간이 뚜렷하지 않습니다.</span>
                        {% endif %}
                      </div>
                    </div>
                  </div>
                </article>
              {% endfor %}
            </div>
          {% else %}
            <p class="empty">이 구간에 해당하는 종목이 없습니다.</p>
          {% endif %}
        </section>
      {% endfor %}

      <section class="section panel">
        <div class="section-title">
          <h2>실패 종목</h2>
          <span class="muted">{{ failures|length }}개 종목</span>
        </div>
        {% if failures %}
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>종목</th>
                  <th>사유</th>
                </tr>
              </thead>
              <tbody>
                {% for symbol, reason in failures.items()|sort %}
                  <tr>
                    <td>{{ symbol }}</td>
                    <td>{{ reason }}</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        {% else %}
          <p class="empty">데이터 수집에 실패한 종목이 없습니다.</p>
        {% endif %}
      </section>

      <p class="footer">본 리포트는 규칙 기반으로 생성되며 투자 판단을 대체하지 않습니다.</p>
    </div>
  </body>
</html>
